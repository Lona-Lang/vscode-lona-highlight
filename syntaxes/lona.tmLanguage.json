{
  "name": "Lona",
  "scopeName": "source.lona",
  "fileTypes": [
    "lo"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#tags"
    },
    {
      "include": "#import-statement"
    },
    {
      "include": "#global-declaration"
    },
    {
      "include": "#trait-declaration"
    },
    {
      "include": "#impl-declaration"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#struct-declaration"
    },
    {
      "include": "#variable-declaration"
    },
    {
      "include": "#const-declaration"
    },
    {
      "include": "#ref-declaration"
    },
    {
      "include": "#short-variable-declaration"
    },
    {
      "include": "#parameter-declaration"
    },
    {
      "include": "#field-declaration"
    },
    {
      "include": "#cast-expression"
    },
    {
      "include": "#function-pointer-reference"
    },
    {
      "include": "#named-argument"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#character-literals"
    },
    {
      "include": "#numeric-literals"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#self"
    },
    {
      "include": "#member-owner"
    },
    {
      "include": "#variable-reference"
    },
    {
      "include": "#member-function-call"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#tuple-member"
    },
    {
      "include": "#member-access"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lona",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lona",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.lona"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.lona"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.lona",
              "match": "\\\\(?:[ntr0\\\\'\"x]|x[0-9A-Fa-f]{1,2})"
            }
          ]
        }
      ]
    },
    "character-literals": {
      "patterns": [
        {
          "name": "constant.character.lona",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.character.begin.lona"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.character.end.lona"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.lona",
              "match": "\\\\(?:[ntr0\\\\'\"x]|x[0-9A-Fa-f]{1,2})"
            }
          ]
        }
      ]
    },
    "numeric-literals": {
      "patterns": [
        {
          "name": "constant.numeric.lona",
          "match": "\\b(?:[0-9]+\\.[0-9]+|[0-9]+)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lona",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.lona",
          "match": "\\bnull\\b"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "storage.type.builtin.lona",
          "match": "\\b(?:type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.type.function.lona",
          "match": "\\bdef\\b"
        },
        {
          "name": "storage.type.struct.lona",
          "match": "\\bstruct\\b"
        },
        {
          "name": "storage.type.trait.lona",
          "match": "\\btrait\\b"
        },
        {
          "name": "keyword.declaration.impl.lona",
          "match": "\\bimpl\\b"
        },
        {
          "name": "storage.type.variable.lona",
          "match": "\\bvar\\b"
        },
        {
          "name": "storage.type.variable.lona",
          "match": "\\bglobal\\b"
        },
        {
          "name": "keyword.control.conditional.lona",
          "match": "\\b(?:if|else|for)\\b"
        },
        {
          "name": "keyword.control.flow.lona",
          "match": "\\b(?:ret|break|continue)\\b"
        },
        {
          "name": "keyword.control.import.lona",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.other.set.lona",
          "match": "\\bset\\b"
        },
        {
          "name": "storage.modifier.lona",
          "match": "\\b(?:ref|const)\\b"
        },
        {
          "name": "storage.modifier.dynamic.lona",
          "match": "\\bdyn\\b"
        },
        {
          "name": "keyword.operator.cast.lona",
          "match": "\\bcast\\b"
        }
      ]
    },
    "self": {
      "patterns": [
        {
          "name": "variable.language.self.lona",
          "match": "\\bself\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.lona",
          "match": "[{}\\[\\](),:#]"
        },
        {
          "name": "punctuation.accessor.dot.lona",
          "match": "\\."
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lona",
          "match": "&<|<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\^=|\\|=|==|!=|<=|>=|<<|>>|&&|\\|\\||[+\\-*/%!~<>&^|=]"
        }
      ]
    },
    "tags": {
      "begin": "#\\[",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.annotation.begin.lona"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.annotation.end.lona"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#character-literals"
        },
        {
          "include": "#numeric-literals"
        },
        {
          "include": "#builtin-types"
        },
        {
          "name": "entity.name.tag.lona",
          "match": "\\b(?:extern|repr)\\b"
        },
        {
          "name": "variable.annotation.argument.lona",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.annotation.lona",
          "match": ","
        }
      ]
    },
    "import-statement": {
      "patterns": [
        {
          "match": "\\b(import)\\b\\s+([A-Za-z0-9_./-]+)",
          "captures": {
            "1": {
              "name": "keyword.control.import.lona"
            },
            "2": {
              "name": "entity.name.namespace.import.lona"
            }
          }
        }
      ]
    },
    "global-declaration": {
      "begin": "\\b(global)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.variable.lona"
        },
        "2": {
          "name": "variable.other.definition.lona"
        }
      },
      "end": "(?=\\s*(?:=|$))",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#type-expression"
        }
      ]
    },
    "struct-declaration": {
      "begin": "\\b(struct)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.struct.lona"
        },
        "2": {
          "name": "entity.name.type.struct.lona"
        }
      },
      "end": "(?=\\{|$)",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#generic-parameters"
        }
      ]
    },
    "trait-declaration": {
      "begin": "\\b(trait)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.trait.lona"
        },
        "2": {
          "name": "entity.name.type.trait.lona"
        }
      },
      "end": "(?=\\{|$)",
      "patterns": [
        {
          "include": "#comments"
        }
      ]
    },
    "impl-declaration": {
      "begin": "\\b(impl)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.declaration.impl.lona"
        }
      },
      "end": "(?=\\{|$)",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#generic-parameters"
        },
        {
          "name": "keyword.control.impl.lona",
          "match": "\\bfor\\b"
        },
        {
          "name": "punctuation.separator.type.lona",
          "match": ":"
        },
        {
          "include": "#type-expression"
        }
      ]
    },
    "generic-parameters": {
      "begin": "\\[",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.type-parameters.begin.lona"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.type-parameters.end.lona"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:,|\\])|\\s+[A-Za-z_][A-Za-z0-9_]*(?:\\.|\\b))",
          "captures": {
            "1": {
              "name": "entity.name.type.type-parameter.lona"
            }
          }
        },
        {
          "include": "#type-expression"
        },
        {
          "name": "punctuation.separator.type-parameter.lona",
          "match": ","
        }
      ]
    },
    "function-declaration": {
      "begin": "\\b(set\\b\\s+)?(def)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "keyword.other.set.lona"
        },
        "2": {
          "name": "storage.type.function.lona"
        },
        "3": {
          "name": "entity.name.function.lona"
        }
      },
      "end": "(?=\\{|$)",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#generic-parameters"
        },
        {
          "begin": "\\(",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.parameters.begin.lona"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parameters.end.lona"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#parameter-declaration"
            },
            {
              "include": "#named-argument"
            },
            {
              "include": "#cast-expression"
            },
            {
              "include": "#function-pointer-reference"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#character-literals"
            },
            {
              "include": "#numeric-literals"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#type-expression"
            },
            {
              "name": "punctuation.separator.parameter.lona",
              "match": ","
            }
          ]
        },
        {
          "begin": "(?<=\\))(?=\\s*(?:<|\\(|\\b(?:type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool)\\b|[A-Za-z_][A-Za-z0-9_]*))",
          "end": "(?=\\{|$)",
          "patterns": [
            {
              "include": "#type-expression"
            }
          ]
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "begin": "\\b(var)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "storage.type.variable.lona"
            },
            "2": {
              "name": "variable.other.definition.lona"
            }
          },
          "end": "(?=\\s*(?:=|$))",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#type-expression"
            }
          ]
        }
      ]
    },
    "const-declaration": {
      "begin": "\\b(const)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.modifier.const.lona"
        },
        "2": {
          "name": "variable.other.constant.definition.lona"
        }
      },
      "end": "(?=\\s*(?:=|$))",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#type-expression"
        }
      ]
    },
    "ref-declaration": {
      "begin": "^\\s*(ref)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.modifier.ref.lona"
        },
        "2": {
          "name": "variable.other.definition.lona"
        }
      },
      "end": "(?=\\s*(?:=|$))",
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#type-expression"
        }
      ]
    },
    "short-variable-declaration": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(:)(=)",
          "captures": {
            "1": {
              "name": "variable.other.definition.lona"
            },
            "2": {
              "name": "punctuation.separator.key-value.lona"
            },
            "3": {
              "name": "keyword.operator.assignment.lona"
            }
          }
        }
      ]
    },
    "parameter-declaration": {
      "patterns": [
        {
          "match": "(?:(?<=\\()|(?<=,))\\s*(ref\\b\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s+(?:<|\\(|\\b(?:type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool)\\b|[A-Za-z_][A-Za-z0-9_]*(?:\\.|\\b)))",
          "captures": {
            "1": {
              "name": "storage.modifier.ref.lona"
            },
            "2": {
              "name": "variable.parameter.lona"
            }
          }
        }
      ]
    },
    "field-declaration": {
      "patterns": [
        {
          "begin": "^\\s*(?!set\\b\\s+def\\b)(?!(?:var|global|const|ref|def|if|for|ret|break|continue|import|struct|else)\\b)(set\\b\\s+)?([A-Za-z_][A-Za-z0-9_]*|_)(?=\\s+(?:<|\\(|\\b(?:type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool)\\b|[A-Za-z_][A-Za-z0-9_]*(?:\\.|\\b)))",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.set.lona"
            },
            "2": {
              "name": "variable.other.member.definition.lona"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#type-expression"
            }
          ]
        }
      ]
    },
    "named-argument": {
      "patterns": [
        {
          "match": "(?:(?<=\\()|(?<=,))\\s*(ref\\b\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(=)",
          "captures": {
            "1": {
              "name": "storage.modifier.ref.lona"
            },
            "2": {
              "name": "variable.parameter.argument.lona"
            },
            "3": {
              "name": "keyword.operator.assignment.lona"
            }
          }
        }
      ]
    },
    "cast-expression": {
      "begin": "\\b(cast)(\\s*\\[)",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.cast.lona"
        },
        "2": {
          "name": "punctuation.section.brackets.begin.lona"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.brackets.end.lona"
        }
      },
      "patterns": [
        {
          "include": "#type-expression"
        }
      ]
    },
    "function-pointer-reference": {
      "begin": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(&<)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.lona"
        },
        "2": {
          "name": "keyword.operator.function-pointer.lona"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.type-arguments.end.lona"
        }
      },
      "patterns": [
        {
          "include": "#type-expression"
        }
      ]
    },
    "type-expression": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#character-literals"
        },
        {
          "include": "#numeric-literals"
        },
        {
          "include": "#builtin-types"
        },
        {
          "name": "storage.modifier.ref.lona",
          "match": "\\bref\\b"
        },
        {
          "name": "storage.modifier.const.lona",
          "match": "\\bconst\\b"
        },
        {
          "name": "storage.modifier.dynamic.lona",
          "match": "\\bdyn\\b"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.lona"
            },
            "2": {
              "name": "punctuation.accessor.dot.lona"
            }
          }
        },
        {
          "name": "entity.name.type.lona",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "keyword.operator.pointer.lona",
          "match": "\\*"
        },
        {
          "name": "punctuation.separator.type.lona",
          "match": "[<>\\[\\](),:]"
        },
        {
          "name": "keyword.operator.lona",
          "match": "[+\\-*/%!~<>&^|=]"
        }
      ]
    },
    "member-function-call": {
      "patterns": [
        {
          "name": "entity.name.function.member.lona",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?:\\(|\\[))"
        }
      ]
    },
    "member-owner": {
      "patterns": [
        {
          "name": "variable.other.object.lona",
          "match": "\\b(?!(?:def|struct|trait|impl|var|global|set|ret|break|continue|if|else|for|import|ref|const|cast|dyn|true|false|null|type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool|self)\\b)[A-Za-z_][A-Za-z0-9_]*\\b(?=\\.)"
        }
      ]
    },
    "variable-reference": {
      "patterns": [
        {
          "name": "variable.other.readwrite.lona",
          "match": "\\b(?!(?:def|struct|trait|impl|var|global|set|ret|break|continue|if|else|for|import|ref|const|cast|dyn|true|false|null|type|u8|i8|u16|i16|u32|i32|u64|i64|int|uint|f32|f64|bool|self)\\b)(?<!\\.)[A-Za-z_][A-Za-z0-9_]*\\b(?!\\s*(?:[:.(]|&<))"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.call.lona",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "tuple-member": {
      "patterns": [
        {
          "name": "variable.other.member.tuple.lona",
          "match": "(?<=\\.)_[0-9]+\\b"
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.lona",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
