{
  "name": "lona-highlight",
  "displayName": "Lona Highlight",
  "description": "Syntax highlighting and editor language support for the Lona programming language.",
  "version": "0.0.3",
  "publisher": "tastynoob",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "lona",
    "syntax-highlighting",
    "compiler"
  ],
  "homepage": "https://github.com/tastynoob/vscode-lona-highlight#readme",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:lona"
  ],
  "bugs": {
    "url": "https://github.com/tastynoob/vscode-lona-highlight/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tastynoob/vscode-lona-highlight.git"
  },
  "files": [
    "extension.js",
    "lona-semantic.js",
    "syntaxes/**",
    "language-configuration.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node tests/semantic.test.js",
    "package": "vsce package --no-dependencies",
    "publish:patch": "vsce publish patch --no-dependencies",
    "publish:minor": "vsce publish minor --no-dependencies"
  },
  "contributes": {
    "configurationDefaults": {
      "[lona]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "languages": [
      {
        "id": "lona",
        "aliases": [
          "Lona",
          "lona"
        ],
        "extensions": [
          ".lo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lona",
        "scopeName": "source.lona",
        "path": "./syntaxes/lona.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
